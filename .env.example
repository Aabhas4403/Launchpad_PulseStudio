# --- Waitlist persistence ----------------------------------------------------
# Pick one. If none are set the API logs to stdout and writes to data/waitlist.json
# (dev only — does not persist on Vercel between deployments).

# Resend (recommended, https://resend.com)
# RESEND_API_KEY=
# RESEND_FROM=hello@yourdomain.com
# RESEND_NOTIFY=you@yourdomain.com

# Loops (https://loops.so)
# LOOPS_API_KEY=

# Vercel Postgres / KV / Supabase — wire in the route at app/api/waitlist/route.ts

# --- Optional analytics ------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# --- Live product app URLs ---------------------------------------------------
# Where the "Launch app" buttons take users. Defaults below match the local
# ports started by scripts/start-all.sh. Override in production with the
# deployed hostnames.
NEXT_PUBLIC_CONTENT_PULSE_URL=http://localhost:5173
NEXT_PUBLIC_SHELF_PULSE_URL=http://localhost:5500
